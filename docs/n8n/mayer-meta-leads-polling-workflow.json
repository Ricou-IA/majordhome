        "facebookGraphApi": {
          "id": "REPLACE_WITH_GRAPH_CRED_ID",
          "name": "Facebook Graph API — Mayer"
        }
      },
      "notes": "Récupère les leads des 30 dernières minutes pour chaque formulaire."
    },
    {
      "parameters": {
        "fieldToSplitOut": "data",
        "options": {}
      },
      "id": "e4c9b2a1-0005-4a10-9000-000000000005",
      "name": "Split Leads",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst fields = raw.field_data || [];\n\nconst getField = (...names) => {\n  for (const name of names) {\n    const f = fields.find((x) => (x.name || '').toLowerCase() === name.toLowerCase());\n    if (f) {\n      const v = Array.isArray(f.values) ? f.values[0] : f.values;\n      if (v != null && v !== '') return String(v).trim();\n    }\n  }\n  return null;\n};\n\nconst cleanPhone = (p) => {\n  if (!p) return null;\n  const kept = p.replace(/[^0-9+]/g, '');\n  return kept || null;\n};\n\nconst cleanPostal = (p) => {\n  if (!p) return null;\n  const m = String(p).match(/\\b\\d{5}\\b/);\n  return m ? m[0] : String(p).replace(/\\D/g, '').slice(0, 5) || null;\n};\n\n// Récupère first_name / last_name, OU tente de splitter un champ 'full name' combiné\nlet firstName = getField('first_name', 'prenom', 'prénom');\nlet lastName = getField('last_name', 'nom', 'family_name');\n\nif (!firstName && !lastName) {\n  const fullName = getField('full_name', 'full name', 'name', 'nom_complet', 'nom complet');\n  if (fullName) {\n    const parts = fullName.trim().split(/\\s+/);\n    firstName = parts[0] || null;\n    lastName = parts.slice(1).join(' ') || null;\n  }\n}\n\nconst normalized = {\n  first_name: firstName ? firstName.toUpperCase() : null,\n  last_name: lastName ? lastName.toUpperCase() : null,\n  email: getField('email'),\n  phone: cleanPhone(getField('phone_number', 'phone', 'telephone', 'téléphone')),\n  postal_code: cleanPostal(getField('post_code', 'zip_code', 'postal_code', 'code_postal', 'codepostal')),\n  city: getField('city', 'ville'),\n  external_id: raw.id || null,\n  created_time: raw.created_time || null,\n  meta_raw: raw,\n};\n\nreturn [{ json: normalized }];"
      },
      "id": "e4c9b2a1-0006-4a10-9000-000000000006",
      "name": "Normalize Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1340,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://odspcxgafcqxjzrarsqf.supabase.co/rest/v1/rpc/assign_commercial_by_postal_code",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "__SUPABASE_SERVICE_ROLE_KEY__"
            },
