            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_postal_code\": {{ JSON.stringify($json.postal_code) }},\n  \"p_org_id\": \"3c68193e-783b-4aa9-bc0d-fb2ce21e99b1\"\n}",
        "options": {}
      },
      "id": "e4c9b2a1-0007-4a10-9000-000000000007",
      "name": "Assign Commercial",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1560,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const normalized = $('Normalize Lead').first().json;\nconst assignRes = $input.first().json;\n\n// La RPC renvoie désormais { commercial_id: \"uuid\" } ou { commercial_id: null }\nconst assignedId = assignRes?.commercial_id || null;\n\nconst ORG_ID = '3c68193e-783b-4aa9-bc0d-fb2ce21e99b1';\nconst SOURCE_META_ADS = 'acbc8b79-5ca5-493e-a671-36963af2429a';\nconst STATUS_NOUVEAU = 'ea926b9a-521c-4012-a60b-85b6f7e5c09c';\n\nconst payload = {\n  p_data: {\n    org_id: ORG_ID,\n    first_name: normalized.first_name,\n    last_name: normalized.last_name,\n    email: normalized.email,\n    phone: normalized.phone,\n    postal_code: normalized.postal_code,\n    city: normalized.city,\n    source_id: SOURCE_META_ADS,\n    status_id: STATUS_NOUVEAU,\n    assigned_user_id: assignedId,\n    probability: 10,\n    notes: `Lead Meta Ads — ${normalized.created_time || new Date().toISOString()}`,\n    external_id: normalized.external_id,\n    external_source: 'meta_ads',\n    external_data: normalized.meta_raw,\n  },\n};\n\nreturn [{ json: payload }];"
      },
