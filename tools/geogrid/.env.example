# === Google Maps Platform ===
GOOGLE_API_KEY=your_api_key_here

# === Etablissement a tracker ===
BUSINESS_NAME=Mayer Energie
PLACE_ID=                          # Optionnel — si vide, match par nom
KEYWORD=climatisation               # Mot-cle de recherche Google Maps

# === Centre de la grille (coordonnees GPS) ===
CENTER_LAT=43.9016
CENTER_LNG=1.8976

# === Parametres du scan ===
RADIUS_KM=5                         # Rayon autour du centre
GRID_SIZE=7                          # Grille NxN (7 = 49 points)
SEARCH_RADIUS_M=1000                 # Rayon de recherche par point (metres)
